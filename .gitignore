# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# NEXUS-OS v3.1 — Security-First .gitignore
# NEVER commit secrets, keys, .env files, or runtime data.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── SECRETS & CREDENTIALS (NEVER COMMIT) ───────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.secret
credentials.json
service-account*.json
.secrets

# ── Dependencies ───────────────────────────────────────────────
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Testing ────────────────────────────────────────────────────
/coverage

# ── Next.js ────────────────────────────────────────────────────
/.next/
/out/

# ── Production ─────────────────────────────────────────────────
/build

# ── OS & Misc ──────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Debug logs ─────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
dev.log
dev.out.log
server.log

# ── TypeScript ─────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Vercel ─────────────────────────────────────────────────────
.vercel

# ── Local / Dev-only ──────────────────────────────────────────
local-*
.claude
.z-ai-config

# ── Python ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
.venv/
venv/
ENV/

# ── Database (runtime data — team runs bun run db:push) ───────
/db/
*.db
*.sqlite
*.sqlite3

# ── Upload directory (user data) ──────────────────────────────
/upload/

# ── Agent context (development artifacts) ─────────────────────
/agent-ctx/

# ── Mini services runtime ─────────────────────────────────────
/mini-services/*/node_modules/

# ── Sandbox ────────────────────────────────────────────────────
/sandbox/

# ── Handoff ────────────────────────────────────────────────────
/handoff/

# ── Download ───────────────────────────────────────────────────
/download/

# ── Temp files ─────────────────────────────────────────────────
package.json.tmp
test
prompt

# ── Server PID ─────────────────────────────────────────────────
server.pid

# ── Prisma ─────────────────────────────────────────────────────
prisma/migration_lock.toml

# ── Skills directory ──────────────────────────────────────────
/skills/
