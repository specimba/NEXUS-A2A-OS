# ─── NEXUS-OS v3.1 Environment Configuration ───
# Copy this file to .env and fill in your API keys

DATABASE_URL=file:./db/custom.db

# ─── Z-AI (Primary — Required) ───
ZAI_API_KEY=sk-your-zai-api-key

# ─── Encryption Secret (Required — for API key vault) ───
ENCRYPTION_SECRET=your-encryption-secret-here

# ─── OpenRouter (Free models available) ───
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# ─── NVIDIA NIM (Free tier with 1K credits) ───
NVIDIA_API_KEY=nvapi-your-nvidia-key

# ─── Groq (Free: 30 RPM LPU inference) ───
GROQ_API_KEY=gsk_your-groq-key

# ─── Kilo Code ───
KILOCODE_API_KEY=your-kilocode-jwt

# ─── OpenCode ───
OPENCODE_API_KEY=sk-your-opencode-key

# ─── SambaNova (Free tier) ───
SAMBANOVA_API_KEY=your-sambanova-key

# ─── OpenAI (May have 0 credits — free models only) ───
OPENAI_API_KEY=sk-proj-your-openai-key

# ─── Cerebras (Free: CS-3 wafer-scale inference) ───
CEREBRAS_API_KEY=csk-your-cerebras-key

# ─── Fireworks (Free serverless — $1 credits) ───
FIREWORKS_API_KEY=fw_your-fireworks-key

# ─── SiliconFlow (Free tier) ───
SILICONFLOW_API_KEY=sk-your-siliconflow-key

# ─── Composio (Tool integration) ───
COMPOSIO_API_KEY=ak_your-composio-key

# ─── Mistral (Experiment plan: 2 RPM, 1B tok/month) ───
MISTRAL_API_KEY=your-mistral-key

# ─── Codestral (Code specialist: 30 RPM) ───
CODESTRAL_API_KEY=your-codestral-key
